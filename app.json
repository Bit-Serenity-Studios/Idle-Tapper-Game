{
  "expo": {
    "name": "Magnum Opus",
    "slug": "magnum-opus",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "magnumopus",
    "newArchEnabled": true,
    "backgroundColor": "#1a1612",
    "splash": {
      "backgroundColor": "#1a1612",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.magnumopus.app"
    },
    "android": {
      "package": "com.magnumopus.app",
      "adaptiveIcon": {
        "backgroundColor": "#1a1612"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/Idle-Tapper-Game"
    }
  }
}
